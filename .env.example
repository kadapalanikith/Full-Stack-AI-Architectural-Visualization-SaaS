# Environment Variables

Copy this file to `.env.local` to run the application locally.

# ─────────────────────────────────────────────
# Puter Worker URL
# ─────────────────────────────────────────────
# The public URL of your deployed Puter Worker.
# This is used by the frontend to communicate with the backend worker
# for project save/load operations.
#
# Format: https://your-worker-name.puter.site
# Leave blank to disable project persistence (render still works).
VITE_PUTER_WORKER_URL=
